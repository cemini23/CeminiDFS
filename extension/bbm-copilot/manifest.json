{
  "manifest_version": 3,
  "name": "CeminiDFS BBM Copilot",
  "version": "1.0.0",
  "description": "Draggable panel for CeminiDFS BBM recommendations - read only, manual sync",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.underdogfantasy.com/*",
    "*://app.underdogfantasy.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.underdogfantasy.com/*",
        "*://app.underdogfantasy.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CeminiDFS BBM Settings"
  }
}
